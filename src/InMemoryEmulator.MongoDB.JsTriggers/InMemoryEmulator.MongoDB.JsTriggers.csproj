<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<PackageId>InMemoryEmulator.MongoDB.JsTriggers</PackageId>
		<Description>JavaScript expression support for InMemoryEmulator.MongoDB. Uses Jint to execute $function, $accumulator, and $where expressions inside your in-memory tests.</Description>
		<PackageTags>mongodb;mongo;testing;javascript;jint;in-memory;emulator</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageIcon>icon.png</PackageIcon>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="" />
		<None Include="..\..\icon.png" Pack="true" PackagePath="" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Jint" Version="4.2.1" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\InMemoryEmulator.MongoDB\InMemoryEmulator.MongoDB.csproj" />
	</ItemGroup>

</Project>
