<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<PackageId>InMemoryEmulator.MongoDB</PackageId>
		<Description>A high-fidelity, in-memory implementation of the MongoDB .NET Driver interfaces — purpose-built for fast, reliable component and integration testing. Drop-in replacements for IMongoClient, IMongoDatabase, and IMongoCollection&lt;T&gt; with full CRUD, filter evaluation, aggregation pipeline, change streams, transactions, LINQ, and DI integration. Zero production code changes required.</Description>
		<PackageTags>mongodb;mongo;testing;in-memory;emulator;mock;fake;integration-testing;component-testing</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageIcon>icon.png</PackageIcon>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="" />
		<None Include="..\..\icon.png" Pack="true" PackagePath="" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="InMemoryEmulator.MongoDB.Tests.Unit" />
		<InternalsVisibleTo Include="InMemoryEmulator.MongoDB.JsTriggers" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="MongoDB.Driver" Version="3.8.1" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.8" />
		<PackageReference Include="NetTopologySuite" Version="2.5.0" />
	</ItemGroup>

</Project>
